// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `zed: Open Default Settings` command
// from the command palette
{
  "base_keymap": "None",
  "language_models": {
    "openai_compatible": {
      "Alibaba": {
        "api_url": "https://coding-intl.dashscope.aliyuncs.com/v1",
        "available_models": [
          {
            "name": "glm-5",
            "max_tokens": 202752,
            "max_output_tokens": 16384,
            "max_completion_tokens": 202752,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          },
          {
            "name": "kimi-k2.5",
            "max_tokens": 262144,
            "max_output_tokens": 32768,
            "max_completion_tokens": 262144,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          },
          {
            "name": "qwen3.5-plus",
            "max_tokens": 1000000,
            "max_output_tokens": 65536,
            "max_completion_tokens": 1000000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "tree_view": false,
    "dock": "right"
  },
  "project_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "claude": {
      "default_config_options": {
        "mode": "acceptEdits"
      }
    },
    "opencode": {
      "type": "registry"
    }
  },
  "agent_ui_font_size": 16.0,
  "ui_font_family": ".ZedSans",
  "buffer_line_height": "standard",
  "icon_theme": "Material Icon Theme",
  "edit_predictions": {
    "codestral": {
      "api_url": "https://codestral.mistral.ai"
    },
    "open_ai_compatible_api": {
      "prompt_format": "infer"
    },
    "provider": "codestral"
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cat\\b"
            }
          ]
        }
      }
    },
    "dock": "left",
    "play_sound_when_agent_done": true,
    "default_model": {
      "provider": "Alibaba",
      "model": "glm-5"
    },
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "system",
    "light": "Vercel Light",
    "dark": "Vercel Dark"
  },
  "tab_size": 2
}
